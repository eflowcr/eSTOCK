# Sensitive / per-environment config. Copy to .env and set real values. Never commit .env.

# Backend API base URL (required; no trailing slash)
API_BASE=http://localhost:8080/api

# Optional overrides (defaults come from environment.base.ts / environment.prod.ts)
# VERSION=v4.20.0.0
# VERSION_BD=4.20.0.0
# TESTING=true
# PRODUCTION=false
